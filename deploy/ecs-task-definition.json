{
  "family": "gsi-standards-rag-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::833239388618:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::833239388618:role/gsiStandardsRagTaskRole",
  "containerDefinitions": [
    {
      "name": "standards-rag-api",
      "image": "833239388618.dkr.ecr.us-east-1.amazonaws.com/gsi-standards-rag-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "AUTH_REQUIRED", "value": "1" },
        { "name": "AWS_REGION", "value": "us-east-1" },
        { "name": "COGNITO_REGION", "value": "us-east-1" },
        { "name": "DYNAMODB_CONVERSATIONS_TABLE", "value": "gsi-conversations" },
        { "name": "USE_OPENAI_ANSWER_REWRITER", "value": "1" },
        { "name": "OPENAI_CHAT_MODEL", "value": "gpt-4o-mini" },
        { "name": "VIDEO_TRANSCRIPTS_PATH", "value": "/app/data/videos/transcripts.json" },
        { "name": "USE_PINECONE", "value": "1" },
        { "name": "PINECONE_INDEX", "value": "gsi" },
        { "name": "PINECONE_INDEX_HOST", "value": "https://gsi-te1od36.svc.aped-4627-b74a.pinecone.io" },
        { "name": "CORS_ALLOW_ORIGINS", "value": "https://dev.d1new0h0uf5on.amplifyapp.com,https://main.d1new0h0uf5on.amplifyapp.com" },
        { "name": "STANDARDS_ASSETS_S3_URI", "value": "s3://gsi-rag-assets-833239388618-us-east-1/" },
        { "name": "STANDARDS_INDEX_PATH", "value": "/app/data/index/standards.json" },
        { "name": "STANDARDS_PDF_ROOT", "value": "/app" }
      ],
      "secrets": [
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:833239388618:secret:gsi/openai-api-key" },
        { "name": "PINECONE_API_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-1:833239388618:secret:gsi/pinecone-api-key" },
        { "name": "COGNITO_USER_POOL_ID", "valueFrom": "arn:aws:ssm:us-east-1:833239388618:parameter/gsi/cognito/user-pool-id" },
        { "name": "COGNITO_APP_CLIENT_ID", "valueFrom": "arn:aws:ssm:us-east-1:833239388618:parameter/gsi/cognito/app-client-id" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/gsi-standards-rag-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
