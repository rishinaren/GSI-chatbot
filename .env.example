# Optional: minimum score for the last-chance full-index search (default 0.0 = any token overlap).
# STANDARDS_SEARCH_MIN_SCORE_RELAXED=0

# Optional OpenAI settings for conversational answer rewriting (post-retrieval).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
USE_OPENAI_ANSWER_REWRITER=0
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional Postgres/pgvector connection for production retrieval.
DATABASE_URL=postgresql://user:password@localhost:5432/standards_rag

# Authentication (optional for local dev; enable in AWS).
AUTH_REQUIRED=0
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_REGION=us-east-1

# Conversation persistence (DynamoDB in AWS; in-memory when unset).
DYNAMODB_CONVERSATIONS_TABLE=
CONVERSATION_TTL_DAYS=90

# Frontend/API deployment helpers.
CORS_ALLOW_ORIGINS=
VITE_API_BASE_URL=

# Local JSON index path used by the dependency-light MVP.
STANDARDS_INDEX_PATH=data/index/standards-index.json

# Optional: restrict PDF download (/documents/.../pdf) to files under this directory (absolute path).
# Leave unset for local dev when source_path in the index already points to allowed PDFs.
# STANDARDS_PDF_ROOT=/path/to/standards/pdfs

# Pinecone vector retrieval (optional).
USE_PINECONE=0
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=
PINECONE_INDEX_HOST=
PINECONE_EMBED_MODEL=llama-text-embed-v2
PINECONE_EMBED_TRUNCATE=END
PINECONE_UPSERT_BATCH=64

# Video transcript retrieval (links questions to YouTube videos).
# JSON file of transcripts; see data/videos/transcripts.json for the format.
VIDEO_TRANSCRIPTS_PATH=data/videos/transcripts.json
# Optional: enrich video metadata via the YouTube Data API (embedding works without it).
YOUTUBE_API_KEY=
